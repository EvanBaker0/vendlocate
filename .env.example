# Vercel environment variables for VendLocate Pro
# These values are read by the /api/scan serverless function.
# They are not used by the Vite build itself, so the app will still build
# without them, but the scan endpoint will fall back to the public defaults
# baked into the source.

# Your Supabase project URL (must match the value used by the frontend).
SUPABASE_URL=https://axawjnoxdlnbicnsxlwj.supabase.co

# Your Supabase anon (publishable) key.
# This is the same key the frontend uses — the serverless function forwards
# the user's JWT for row-level security, so this only needs to be the anon key.
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImF4YXdqbm94ZGxuYmljbnN4bHdqIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODAyNjkzMzEsImV4cCI6MjA5NTg0NTMzMX0.FVg-2ah8ZK5AQwFhoLAubrxDO-Rxk4FzEiBRgZ9hb_I

# Optional: if you ever want to bypass RLS from the serverless function
# (not currently needed), set the service role key here.
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
